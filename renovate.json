{
  "extends": [
    "config:base",
    ":gitSignOff",
    ":disableDependencyDashboard"
  ],
  "ignorePaths": [
    ".github/**"
  ],
  "labels": [
    "dependency"
  ],
  "separateMinorPatch": true,
  "suppressNotifications": [
    "artifactErrors"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": [
        "patch",
        "digest"
      ],
      "matchCurrentVersion": "!/^v?0\\./",
      "automerge": true,
      "platformAutomerge": false,
      "labels": [
        "dependency",
        "automerge",
        "bump:patch"
      ]
    },
    {
      "automerge": true,
      "platformAutomerge": false,
      "matchDatasources": [
        "docker"
      ],
      "labels": [
        "dependency",
        "automerge",
        "bump:minor"
      ]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/.*.ya?ml/"
      ],
      "matchStrings": [
        "datasource=(?<datasource>.*?) depName=(?<depName>.*?)?\\s.*(image): [^:]*:(?<currentValue>.*)\"\\s"
      ]
    }
  ]
}
